# ─────────────────────────────────────────────────────────────
# BRUE · environment variables
# Copy this file to .env.local for local dev.
# In Vercel, add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — Settings → API → Project API keys → anon/public
# Safe to expose to the browser. RLS controls what this key can read/write.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase SERVICE ROLE key — Settings → API → Project API keys → service_role
# SERVER-ONLY. Bypasses RLS. NEVER prefix with NEXT_PUBLIC_. Used by:
#   - /api/orders POST (trusted insert after server-side validation)
#   - /r/[id] receipt page (anon can no longer SELECT orders directly,
#     see supabase/migrations/006_security_lockdown.sql)
# Without this, /api/orders and the receipt page return 500.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# WhatsApp number used for the public menu's checkout and the "Send update"
# button in /admin/orders. Digits only — no +, no spaces, country code first.
# e.g. 92 300 1234567 → 923001234567
NEXT_PUBLIC_WHATSAPP_NUMBER=923XXXXXXXXX

# ─────────────────────────────────────────────────────────────
# Rate limiting on /api/orders (recommended, fail-open if unset)
#
# Sign up free at https://upstash.com → Console → Create Redis Database
# → REST tab → copy URL + Token. Free tier: 10,000 commands/day, plenty
# for a small cafe (each order = 2 commands).
#
# If these are NOT set, /api/orders runs with NO rate limit and logs a
# warning to the server console. Site stays up either way.
# ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXXXXXXX

# ─────────────────────────────────────────────────────────────
# Not env vars — but note: everything else (shop name, lat/lng,
# hours, covered delivery areas, Instagram, Bykea/inDrive methods…)
# is configured in `lib/shop.ts`. See README § 3 before your first
# deploy — the lat/lng shipped there are a Karachi placeholder
# and MUST be replaced with the real BRUE pin so /find-us maps and
# the Directions link point to the actual bar.
# ─────────────────────────────────────────────────────────────
