# ─────────────────────────────────────────────────────────────
# BRUE · environment variables
# Copy this file to .env.local for local dev.
# In Vercel, add these under Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Supabase project URL — Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon (public) key — Settings → API → Project API keys → anon/public
# Safe to expose to the browser. RLS controls what this key can read/write.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# WhatsApp number used for the public menu's checkout and the "Send update"
# button in /admin/orders. Digits only — no +, no spaces, country code first.
# e.g. 92 300 1234567 → 923001234567
NEXT_PUBLIC_WHATSAPP_NUMBER=923XXXXXXXXX

# ─────────────────────────────────────────────────────────────
# Not env vars — but note: everything else (shop name, lat/lng,
# hours, covered delivery areas, Instagram, Bykea/inDrive methods…)
# is configured in `lib/shop.ts`. See README § 3 before your first
# deploy — the lat/lng shipped there are a Karachi placeholder
# and MUST be replaced with the real BRUE pin so /find-us maps and
# the Directions link point to the actual bar.
# ─────────────────────────────────────────────────────────────
